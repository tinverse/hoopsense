# HoopSense Environment Config
export GCP_PROJECT_ID="hoopsense-ai"
export GCP_REGION="us-central1"

# Remote SSH Config (Update after running tunnel script in Colab)
export HOOPS_REMOTE_HOST="root@0.tcp.ngrok.io" 
export HOOPS_REMOTE_PORT="22"
export HOOPS_REMOTE_DIR="/content/hoopsense"

# GCloud SDK Integration
if [ -f "$HOME/dotfiles/opt/google-cloud-sdk/path.bash.inc" ]; then
    source "$HOME/dotfiles/opt/google-cloud-sdk/path.bash.inc"
fi
